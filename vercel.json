{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/*.php": { "runtime": "vercel-php@0.6.2" }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/build/$1"
    },
    {
      "src": "/(css|js|images|fonts|cv|storage)/(.*)",
      "dest": "/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
